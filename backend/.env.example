# Copy this to .env for local development only.
# In Cloud Run, set these via Secret Manager (see README).

# Your Odds API key from https://the-odds-api.com/account/
ODDS_API_KEY=8d96d1f0daa60bcd931806eb52232cbc

# Admin key for creating/revoking FSU consumer keys.
# Generate with: python -c "import secrets; print('admin_' + secrets.token_urlsafe(32))"
ADMIN_KEY=your_admin_key_here

# GCP project (already set as default for Cloud Run)
GCP_PROJECT=chimera-v4

# CORS — comma-separated list. Use * for dev, your Cloudflare domain for prod.
ALLOWED_ORIGINS=["*"]
